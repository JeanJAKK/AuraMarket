<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menu Vendeurs dans la navbar website -->
    <record id="menu_vendors" model="website.menu">
        <field name="name">Vendeurs</field>
        <field name="url">/vendors</field>
        <field name="website_id" ref="website.default_website"/>
        <field name="sequence">50</field>
    </record>

    <!-- Menu Marketplace (page accueil) -->
    <record id="menu_marketplace" model="website.menu">
        <field name="name">Marketplace</field>
        <field name="url">/marketplace</field>
        <field name="website_id" ref="website.default_website"/>
        <field name="sequence">40</field>
    </record>
</odoo>