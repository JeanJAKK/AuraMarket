<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Panier -->
    <template id="cart_page" name="Panier">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-5" style="max-width:700px;">
                    <h1 class="fw-bold mb-4">Mon panier</h1>

                    <t t-if="not cart_items">
                        <div class="text-center py-5">
                            <p class="text-muted fs-5">Votre panier est vide.</p>
                            <a href="/vendors" class="btn btn-primary">Voir les vendeurs</a>
                        </div>
                    </t>

                    <t t-if="cart_items">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-0">
                                <t t-foreach="cart_items" t-as="item">
                                    <div class="d-flex align-items-center justify-content-between p-4 border-bottom">
                                        <div class="d-flex align-items-center gap-3">
                                            <t t-if="item['product'].image_1920">
                                                <img t-attf-src="/web/image/product.template/#{item['product'].id}/image_1920/60x60"
                                                    class="rounded" width="60" height="60" style="object-fit:cover;"/>
                                            </t>
                                            <div>
                                                <div class="fw-bold"><t t-esc="item['product'].name"/></div>
                                                <small class="text-muted">
                                                    <t t-esc="item['product'].vendor_id.shop_name or item['product'].vendor_id.name"/>
                                                </small>
                                            </div>
                                        </div>
                                        <div class="d-flex align-items-center gap-4">
                                            <div class="text-center">
                                                <div class="text-muted small">Qté</div>
                                                <div class="fw-bold"><t t-esc="item['qty']"/></div>
                                            </div>
                                            <div class="text-center">
                                                <div class="text-muted small">Prix</div>
                                                <div class="fw-bold text-primary">
                                                    <t t-esc="item['subtotal']"/> FCFA
                                                </div>
                                            </div>
                                            <a t-attf-href="/marketplace/cart/remove/#{item['product'].id}"
                                                class="btn btn-sm btn-outline-danger">✕</a>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- Total -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between fw-bold fs-5">
                                    <span>Total</span>
                                    <span class="text-primary"><t t-esc="total"/> FCFA</span>
                                </div>
                            </div>
                        </div>

                        <!-- Checkout -->
                        <form action="/marketplace/checkout" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-primary btn-lg w-100">
                                Confirmer et payer
                            </button>
                        </form>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- Confirmation commande -->
    <template id="checkout_success" name="Commande confirmée">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-5" style="max-width:700px;">

                    <!-- En-tête succès -->
                    <div class="text-center mb-5">
                        <div style="font-size:64px;">✓</div>
                        <h1 class="fw-bold text-success">Commande confirmée !</h1>
                        <p class="text-muted">
                            Référence : <strong><t t-esc="sale_order.name"/></strong>
                        </p>
                    </div>

                    <!-- Sous-commandes par vendeur -->
                    <h4 class="mb-3">Détail par vendeur</h4>
                    <t t-foreach="mp_orders" t-as="order">
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fw-bold mb-0">
                                        <t t-esc="order.vendor_id.shop_name or order.vendor_id.name"/>
                                    </h5>
                                    <span class="badge bg-success">Payé</span>
                                </div>
                                <t t-foreach="order.line_ids" t-as="line">
                                    <div class="d-flex justify-content-between text-muted small mb-1">
                                        <span>
                                            <t t-esc="line.product_id.name"/> × <t t-esc="line.quantity"/>
                                        </span>
                                        <span><t t-esc="line.subtotal"/> FCFA</span>
                                    </div>
                                </t>
                                <hr/>
                                <div class="d-flex justify-content-between fw-bold">
                                    <span>Total</span>
                                    <span><t t-esc="order.amount_total"/> FCFA</span>
                                </div>
                            </div>
                        </div>
                    </t>

                    <div class="text-center mt-4">
                        <a href="/vendors" class="btn btn-outline-primary me-2">Continuer mes achats</a>
                        <a href="/my/orders" class="btn btn-primary">Mes commandes</a>
                    </div>

                </div>
            </div>
        </t>
    </template>

</odoo>
