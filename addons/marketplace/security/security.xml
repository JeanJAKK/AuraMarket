<odoo>
    <record id="module_category_marketplace" model="ir.module.category">
        <field name="name">Marketplace</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_marketplace_vendor" model="res.groups">
        <field name="name">Marketplace Vendor</field>
        <field name="category_id" ref="marketplace.module_category_marketplace"/>
    </record>

    <record id="group_marketplace_customer" model="res.groups">
        <field name="name">Marketplace Customer</field>
        <field name="category_id" ref="marketplace.module_category_marketplace"/>
    </record>

    <record id="seq_marketplace_order" model="ir.sequence">
        <field name="name">Marketplace Order</field>
        <field name="code">marketplace.order</field>
        <field name="prefix">MKT/%(year)s/</field>
        <field name="padding">4</field>
    </record>
</odoo>